# Copy to .env and adjust. Used by Alembic and the FastAPI app.

# Local Docker Compose default:
DATABASE_URL=postgresql+psycopg2://faceapp:faceapp@localhost:5432/face_recognition

# Face model must match embedding_dimension (ArcFace -> 512). Re-enroll after changing FACE_MODEL.
# FACE_MODEL=ArcFace
# DETECTOR_BACKEND=retinaface
# MAX_COSINE_DISTANCE=0.6
# UPLOAD_DIR=data/uploads
# MAX_UPLOAD_MB=32
# Video identify: same ArcFace embeddings + max_cosine_distance as photo; default detector retinaface (CPU-heavy).
# VIDEO_FRAME_STRIDE=30
# VIDEO_MAX_FRAMES=36
# VIDEO_DETECTOR_BACKEND=retinaface
# VIDEO_FRAME_MAX_SIDE=640
